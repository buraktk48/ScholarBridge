@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="app-content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h3 class="mb-0">Hoş Geldiniz!</h3>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a href="#">Ana Sayfa</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="container-fluid mt-3">
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<div class="app-content">
    <div class="container-fluid">
        <div class="row">

            @* VAKIF (ORGANIZATION) İÇİN GÖSTERİLECEK KARTLAR *@
            @if (User.IsInRole("Organization"))
            {
                <div class="col-lg-4 col-12">
                    <div class="small-box text-bg-primary">
                        <div class="inner">
                            <h3>@ViewBag.ScholarshipCount</h3>
                            <p>Yayındaki Burs İlanlarım</p>
                        </div>
                        <div class="small-box-icon">
                            <i class="bi bi-megaphone-fill"></i>
                        </div>
                        <a href="/Organization/ScholarshipList" class="small-box-footer">İlanlarımı Gör <i class="bi bi-arrow-right-circle-fill"></i></a>
                    </div>
                </div>

                <div class="col-lg-4 col-12">
                    <div class="small-box text-bg-warning">
                        <div class="inner">
                            <h3>@ViewBag.ApplicationCount</h3>
                            <p>Bekleyen Öğrenci Başvuruları</p>
                        </div>
                        <div class="small-box-icon">
                            <i class="bi bi-file-earmark-person-fill"></i>
                        </div>
                        <a href="/Organization/Applications" class="small-box-footer">Başvuruları İncele <i class="bi bi-arrow-right-circle-fill"></i></a>
                    </div>
                </div>
            }

@if (User.IsInRole("Donor"))
{
    <div class="col-lg-4 col-12">
        <div class="small-box text-bg-success">
            <div class="inner">
                <h3>@ViewBag.DonationCount</h3>
                <p>Bağış Yapılabilecek Burslar</p>
            </div>
            <div class="small-box-icon">
                <i class="bi bi-hand-thumbs-up"></i>
            </div>
            <a href="/Donor/Donate" class="small-box-footer">Bağış Yap <i class="bi bi-arrow-right-circle-fill"></i></a>
        </div>
    </div>
    <div class="col-lg-4 col-12">
        <div class="small-box text-bg-primary">
            <div class="inner">
                <h3>@ViewBag.TotalDonated?.ToString("C0")</h3>
                <p>Toplam Bağış Tutarı</p>
            </div>
            <div class="small-box-icon">
                <i class="bi bi-cash-stack"></i>
            </div>
            <a href="/Donor/Donate" class="small-box-footer">Detaylar <i class="bi bi-arrow-right-circle-fill"></i></a>
        </div>
    </div>
}

            @* ÖĞRENCİ İÇİN GÖSTERİLECEK KARTLAR *@
            @if (User.IsInRole("Student"))
            {
                <div class="col-lg-4 col-12">
                    <div class="small-box text-bg-info">
                        <div class="inner">
                            <h3>@ViewBag.ActiveScholarships</h3>
                            <p>Sistemdeki Aktif İlanlar</p>
                        </div>
                        <div class="small-box-icon">
                            <i class="bi bi-search"></i>
                        </div>
                        <a href="/Student/Scholarships" class="small-box-footer">Burs Ara <i class="bi bi-arrow-right-circle-fill"></i></a>
                    </div>
                </div>

    <div class="col-lg-4 col-12">
        <div class="small-box text-bg-warning">
            <div class="inner">
                <h3>@ViewBag.PendingApplications</h3>
                <p>Bekleyen Başvurularım</p>
            </div>
            <div class="small-box-icon">
                <i class="bi bi-hourglass-split"></i>
            </div>
            <a href="/Student/MyApplications" class="small-box-footer">Başvurularımı Gör <i class="bi bi-arrow-right-circle-fill"></i></a>
        </div>
    </div>

    <div class="col-lg-4 col-12">
        <div class="small-box text-bg-success">
            <div class="inner">
                <h3>@ViewBag.ApprovedApplications</h3>
                <p>Onaylanan Burslarım</p>
            </div>
            <div class="small-box-icon">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <a href="#" class="small-box-footer">Detaylar <i class="bi bi-arrow-right-circle-fill"></i></a>
        </div>
    </div>
}


        </div>
    </div>
</div>
