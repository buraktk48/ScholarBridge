@model IEnumerable<ScholarBridge.Models.Application>

@{
    ViewData["Title"] = "Başvurularım";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h3 class="mb-0"><i class="bi bi-card-checklist me-2"></i> Geçmiş Başvurularım</h3>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Burs Adı</th>
                                <th>Başvuru Tarihi</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@(item.ScholarshipFk?.Title ?? "Burs Bulunamadı")</td>
                                    <td>@(item.AppliedAt.HasValue ? item.AppliedAt.Value.ToString("dd.MM.yyyy HH:mm") : "-")</td>
                                    <td>
                                        @if (item.Status == "Bekliyor")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i> Bekliyor</span>
                                        }
                                        else if (item.Status == "Onaylandı")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i> Onaylandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-circle-fill me-1"></i> Reddedildi</span>
                                        }
                                    </td>
                                    <td>
                                        <!-- İlanı Gör diyince bursa ait View sayfasına geri yolluyoruz -->
                                        <a href="/Student/Application/@item.ScholarshipFkId" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i> İlanı Gör
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                    <h5>Henüz hiçbir bursa başvurmadınız.</h5>
                    <p>Hemen "Burs Ara" sayfasına giderek size uygun bursları keşfedin.</p>
                    <a href="/Student/Scholarships" class="btn btn-primary mt-2">Burs Ara</a>
                </div>
            }
        </div>
    </div>
</div>
