@{
    Layout = null;
}
<!doctype html>
<html lang="tr">
<!--begin::Head-->
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>ScholarBridge | Kayıt Ol</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#007bff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />

    <meta name="title" content="ScholarBridge | Kayıt Ol" />
    <meta name="author" content="ScholarBridge" />
    <meta name="description" content="ScholarBridge - Akademik Köprü" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@fontsource/source-sans-3@5.0.12/index.css"
          integrity="sha256-tXJfXfp6Ewt1ilPzLDtQnJV4hclT9XuaZUKyUvmyr+Q="
          crossorigin="anonymous"
          media="print"
          onload="this.media = 'all'" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css"
          crossorigin="anonymous" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
          crossorigin="anonymous" />

    <link rel="stylesheet" href="~/css/adminlte.css" />
    
    <style>
        .register-box { width: 500px; margin: 5vh auto; }
        @@media (max-width: 576px) { .register-box { width: 90%; } }
        .nav-pills .nav-link { cursor: pointer; font-weight: 600; color: #495057; }
        .nav-pills .nav-link.active { background-color: #0d6efd; color: #fff; }
        .nav-pills .nav-link i { font-size: 1.5rem; }
    </style>
</head>
<!--end::Head-->
<!--begin::Body-->
<body class="register-page bg-body-secondary">
    <div class="register-box">
        <div class="card card-outline card-primary">
            <div class="card-header text-center">
                <a href="/" class="link-dark link-offset-2 link-opacity-100 link-opacity-50-hover">
                    <h1 class="mb-0"><b>Scholar</b>Bridge</h1>
                </a>
            </div>
            <div class="card-body register-card-body">
                <p class="login-box-msg mb-4">Aramıza katılmak için hesap türünüzü seçin</p>

                <!-- Role Selection Tabs -->
                <ul class="nav nav-pills nav-fill mb-4" id="roleTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="student-tab" data-bs-toggle="pill" href="#student-form" role="tab" aria-controls="student-form" aria-selected="true">
                            <i class="bi bi-mortarboard-fill d-block mb-1"></i> Öğrenci
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="foundation-tab" data-bs-toggle="pill" href="#foundation-form" role="tab" aria-controls="foundation-form" aria-selected="false">
                            <i class="bi bi-building-fill d-block mb-1"></i> Vakıf
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="donor-tab" data-bs-toggle="pill" href="#donor-form" role="tab" aria-controls="donor-form" aria-selected="false">
                            <i class="bi bi-heart-fill d-block mb-1"></i> Bağışçı
                        </a>
                    </li>
                </ul>

                <div class="tab-content" id="roleTabsContent">
                    <!-- Student Form -->
                    <div class="tab-pane fade show active" id="student-form" role="tabpanel" aria-labelledby="student-tab">
                        <form action="/Account/RegisterStudent" method="post">
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="studentName" name="StudentName" type="text" class="form-control" placeholder="" required />
                                    <label for="studentName">Adınız</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-person"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="studentSurname" name="StudentSurname" type="text" class="form-control" placeholder="" required />
                                    <label for="studentSurname">Soyadınız</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-person"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="studentEmail" name="Email" type="email" class="form-control" placeholder="" required />
                                    <label for="studentEmail">Üniversite E-posta (.edu.tr)</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-envelope"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="studentPassword" name="PasswordHash" type="password" class="form-control" placeholder="" required />
                                    <label for="studentPassword">Şifre</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-lock-fill"></span></div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Öğrenci Olarak Kayıt Ol</button>
                        </form>
                    </div>

                    <!-- Foundation Form -->
                    <div class="tab-pane fade" id="foundation-form" role="tabpanel" aria-labelledby="foundation-tab">
                        <form action="/Account/RegisterOrganization" method="post">
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="foundationName" name="OrgName" type="text" class="form-control" placeholder="" required />
                                    <label for="foundationName">Vakıf / Kurum Adı</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-building"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="foundationEmail" name="Email" type="email" class="form-control" placeholder="" required />
                                    <label for="foundationEmail">Kurumsal E-posta</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-envelope"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="foundationTax" name="TaxNumber" type="text" class="form-control" placeholder="" required />
                                    <label for="foundationTax">Vergi / Mersis No</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-file-earmark-text"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="foundationPassword" name="PasswordHash" type="password" class="form-control" placeholder="" required />
                                    <label for="foundationPassword">Şifre</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-lock-fill"></span></div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Vakıf Olarak Kayıt Ol</button>
                        </form>
                    </div>

                    <!-- Donor Form -->
                    <div class="tab-pane fade" id="donor-form" role="tabpanel" aria-labelledby="donor-tab">
                        <form action="/Account/RegisterDonor" method="post">
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="donorName" name="DonorName" type="text" class="form-control" placeholder="" required />
                                    <label for="donorName">Ad / Firma Adı</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-person"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="donorSurname" name="DonorSurname" type="text" class="form-control" placeholder="" />
                                    <label for="donorSurname">Soyad (Şahıslar için)</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-person"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="donorEmail" name="Email" type="email" class="form-control" placeholder="" required />
                                    <label for="donorEmail">E-posta</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-envelope"></span></div>
                            </div>
                            <div class="input-group mb-3">
                                <div class="form-floating">
                                    <input id="donorPassword" name="PasswordHash" type="password" class="form-control" placeholder="" required />
                                    <label for="donorPassword">Şifre</label>
                                </div>
                                <div class="input-group-text"><span class="bi bi-lock-fill"></span></div>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Bağışçı Olarak Kayıt Ol</button>
                        </form>
                    </div>
                </div>

                <p class="mb-0 mt-4 text-center">
                    <a href="/Account/Login" class="text-center">Zaten bir hesabım var</a>
                </p>
            </div>
            <!-- /.register-card-body -->
        </div>
    </div>
    
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@popperjs/core@2.11.8/dist/umd/popper.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>
    <script src="~/js/adminlte.js"></script>
</body>
</html>
