@model ScholarBridge.Models.Scholarship

@{
    ViewData["Title"] = "Burs İlanını Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card card-warning card-outline shadow-sm">
                <div class="card-header">
                    <h3 class="card-title"><i class="bi bi-pencil-square me-2 text-warning"></i> Burs İlanını Güncelle</h3>
                </div>
                <!-- /.card-header -->
                <!-- form start -->
                <form asp-action="EditScholarship" method="post">
                    
                    <!-- ÇOK ÖNEMLİ: Hangi bursu güncellediğimizi bilmesi için gizli ID kutusu -->
                    <input type="hidden" asp-for="ScholarshipId" />
                    
                    <!-- Güvenlik için UserFkId'yi de gizli yollayabiliriz (isteğe bağlı) -->
                    <input type="hidden" asp-for="UserFkId" />

                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">İlan Başlığı</label>
                            <input type="text" class="form-control" asp-for="Title" placeholder="Örn: 2025-2026 Eğitim Dönemi Üstün Başarı Bursu" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="AmountPerStudent" class="form-label">Aylık Burs Miktarı (₺)</label>
                                <div class="input-group">
                                    <span class="input-group-text">₺</span>
                                    <input type="number" class="form-control" asp-for="AmountPerStudent" placeholder="Örn: 2500" required>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DurationInMonths" class="form-label">Süresi (Ay)</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" asp-for="DurationInMonths" placeholder="Örn: 9" required>
                                    <span class="input-group-text">Ay</span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Quota" class="form-label">Kontenjan (Kişi Sayısı)</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-people-fill"></i></span>
                                    <input type="number" class="form-control" asp-for="Quota" placeholder="Kaç öğrenciye verilecek?" required>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Deadline" class="form-label">Son Başvuru Tarihi</label>
                                <input type="date" class="form-control" asp-for="Deadline" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RequirementSummary" class="form-label">Başvuru Şartları & Açıklama</label>
                            <textarea class="form-control" asp-for="RequirementSummary" rows="4" placeholder="Bursun şartlarını, kimlerin başvurabileceğini ve diğer detayları buraya yazınız..."></textarea>
                        </div>

                        <div class="mb-4 form-check form-switch p-3 bg-light rounded border border-warning">
                            <input class="form-check-input fs-4 ms-0 mt-2 me-3" type="checkbox" role="switch" id="RequiresDocument" name="RequiresDocument" value="true" @(Model.RequiresDocument == true ? "checked" : "")>
                            <input type="hidden" name="RequiresDocument" value="false">
                            <label class="form-check-label pt-1" for="RequiresDocument">
                                <strong class="text-dark">Bu Burs İçin Öğrenciden Ek Belge Talep Ediyorum</strong> <br>
                                <small class="text-muted">Eğer işaretlerseniz, öğrenciler başvuru sırasında transkript, niyet mektubu gibi özel bir belge yüklemek <b>zorunda</b> kalacaktır.</small>
                            </label>
                        </div>
                    </div>
                    <!-- /.card-body -->

                    <div class="card-footer text-end">
                        <a href="/Organization/ScholarshipList" class="btn btn-outline-secondary me-2">İptal</a>
                        <button type="submit" class="btn btn-warning"><i class="bi bi-save-fill me-1"></i> Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
