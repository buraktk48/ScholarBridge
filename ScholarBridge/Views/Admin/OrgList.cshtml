@model List<ScholarBridge.Models.UserRole>

@{
    ViewData["Title"] = "Kurum Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4">Sistemdeki Kurumlar (Vakıflar)</h6>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Kurum Adı</th>
                                <th scope="col">Vergi Numarası</th>
                                <th scope="col">Email</th>
                                <th scope="col">Telefon</th>
                                <th scope="col">Kayıt Tarihi</th>
                                <th scope="col">Durum</th>
                                <th scope="col">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                int count = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <th scope="row">@count</th>
                                        <td class="fw-bold">
                                            @(item.UserFk?.OrganizationDetail?.OrgName ?? "Bilinmiyor")
                                        </td>
                                        <td>
                                            @(item.UserFk?.OrganizationDetail?.TaxNumber ?? "-")
                                        </td>
                                        <td>@item.UserFk?.Email</td>
                                        <td>@(item.UserFk?.PhoneNumber ?? "-")</td>
                                        <td>@(item.UserFk?.CreatedAt?.ToString("dd/MM/yyyy") ?? "-")</td>
                                        <td>
                                            @if (item.UserFk?.OrganizationDetail?.IsVerified == true)
                                            {
                                                <span class="badge bg-success">Onaylı</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Bekliyor</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.UserFk?.OrganizationDetail != null)
                                            {
                                                @if (item.UserFk.OrganizationDetail.IsVerified != true)
                                                {
                                                    <form asp-action="ApproveOrg" method="post" style="display:inline;">
                                                        <input type="hidden" name="userId" value="@item.UserFk.UserId" />
                                                        <button type="submit" class="btn btn-sm btn-success">Onayla</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form asp-action="RejectOrg" method="post" style="display:inline;">
                                                        <input type="hidden" name="userId" value="@item.UserFk.UserId" />
                                                        <button type="submit" class="btn btn-sm btn-danger">Reddet</button>
                                                    </form>
                                                }
                                            }
                                        </td>
                                    </tr>
                                    count++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center">Kayıtlı kurum bulunmamaktadır.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
